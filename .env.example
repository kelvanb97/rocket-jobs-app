SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
POSTGRES_PASSWORD=supabase-postgres
# For local Docker setup, these must be valid HS256 JWTs signed with the JWT_SECRET in docker-compose.yml
SUPABASE_PUBLISHABLE_KEY=anon-key
SUPABASE_SECRET_KEY=service-key

LLM_PROVIDER=anthropic # Options: anthropic, ollama

# Anthropic (required by web, score)
ANTHROPIC_API_KEY=

# Ollama (optional alternative)
LLM_PROVIDER=anthropic # Options: anthropic, ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Web app — optional model overrides
# APPLY_KEYWORD_MODEL=claude-haiku-4-5-20251001
# APPLY_RESUME_MODEL=claude-opus-4-6-20250619

# Score app — optional overrides
# SCORE_MODEL=claude-haiku-4-5-20251001
# SCORE_BATCH_SIZE=5
# SCORE_RATE_LIMIT_MS=500

# Workflow automation (optional)
# GITHUB_TOKEN=
