{
	"name": "@aja-app/scorer",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"score": "node --env-file=.env --import=tsx src/index.ts",
		"label": "node --env-file=.env --import=tsx src/index.ts --label",
		"eval-ar": "node --env-file=.env --import=tsx autoresearch/scripts/eval.ts",
		"backfill-eval": "node --env-file=.env --import=tsx src/index.ts --backfill",
		"check-types": "tsc --noEmit",
		"lint": "eslint ./src"
	},
	"dependencies": {
		"@aja-api/company": "workspace:*",
		"@aja-api/role": "workspace:*",
		"@aja-api/score": "workspace:*",
		"@aja-integrations/anthropic": "workspace:*",
		"@aja-core/result": "workspace:*",
		"@aja-core/supabase": "workspace:*",
		"@anthropic-ai/sdk": "0.52.0",
		"html-to-text": "9.0.5",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@aja-app/supabase": "workspace:*",
		"@aja-core/eslint": "workspace:*",
		"@aja-core/tsconfig": "workspace:*",
		"@types/node": "25.5.0",
		"eslint": "9.24.0",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	}
}
