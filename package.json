{
	"name": "auto-job-app",
	"private": true,
	"version": "0.0.0",
	"engines": {
		"node": ">=25",
		"pnpm": ">=10"
	},
	"packageManager": "pnpm@10.6.4",
	"scripts": {
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"depcheck": "pnpm -r --workspace-concurrency=1 exec -- sh -c 'echo \"\n$PNPM_PACKAGE_NAME\" && depcheck || true'",
		"destroy-cache": "rm -rf .turbo; find . -type d -path '*/*/.turbo' -print0 | xargs -0 rm -rf; rm -rf .next; find . -type d -path '*/*/.next' -print0 | xargs -0 rm -rf",
		"dev": "turbo run dev",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css}\"",
		"lint": "turbo run lint",
		"postinstall": "pnpm rebuild better-sqlite3",
		"prepare": "husky",
		"purge": "rm -rf node_modules; find . -type d -path '*/*/node_modules' -print0 | xargs -0 rm -rf",
		"test": "turbo run test",
		"workflow:start": "sh -c 'set -a && . .env && set +a && symphony --workflow WORKFLOW.md'",
		"workflow:stop": "sh -c 'lsof -ti :8090 | xargs kill -SIGTERM 2>/dev/null || echo \"No workflow process found on port 8090\"'"
	},
	"dependencies": {
		"husky": "9.1.7"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		]
	},
	"devDependencies": {
		"@commitlint/cli": "20.4.4",
		"@commitlint/config-conventional": "20.4.4",
		"@commitlint/types": "20.4.4",
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"conventional-changelog-atom": "5.1.0",
		"depcheck": "1.4.7",
		"lint-staged": "16.4.0",
		"prettier": "3.8.1",
		"syncpack": "14.2.0",
		"turbo": "2.8.17",
		"typescript": "5.9.3"
	}
}
