{
	"name": "@rja-api/cover-letter",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./api/*": "./src/api/*.ts",
		"./schema/*": "./src/schema/*.ts"
	},
	"scripts": {
		"check-types": "tsc --noEmit",
		"lint": "eslint ./src"
	},
	"dependencies": {
		"@rja-api/company": "workspace:*",
		"@rja-api/role": "workspace:*",
		"@rja-config/user": "workspace:*",
		"@rja-integrations/anthropic": "workspace:*",
		"docx": "9.5.0"
	},
	"peerDependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@rja-core/eslint": "workspace:*",
		"@rja-core/tsconfig": "workspace:*",
		"@types/node": "25.5.0",
		"eslint": "9.24.0",
		"typescript": "5.9.3",
		"zod": "4.3.6"
	},
	"imports": {
		"#*": [
			"./src/*",
			"./src/*.ts",
			"./src/*.tsx"
		],
		"#api*": [
			"./src/api*",
			"./src/api*.ts"
		],
		"#schema*": [
			"./src/schema*",
			"./src/schema*.ts"
		]
	}
}
