{
	"name": "@rja-api/storage",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./api/*": "./src/api/*.ts"
	},
	"scripts": {
		"check-types": "tsc --noEmit",
		"lint": "eslint ./src"
	},
	"dependencies": {
		"@rja-core/result": "workspace:*"
	},
	"devDependencies": {
		"@rja-core/eslint": "workspace:*",
		"@rja-core/tsconfig": "workspace:*",
		"eslint": "9.24.0",
		"@types/node": "25.5.0",
		"typescript": "5.9.3"
	},
	"imports": {
		"#*": [
			"./src/*",
			"./src/*.ts",
			"./src/*.tsx"
		],
		"#api*": [
			"./src/api*",
			"./src/api*.ts"
		]
	}
}
