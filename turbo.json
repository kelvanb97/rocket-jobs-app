{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalDependencies": [".env"],
	"tasks": {
		"build": {
			"env": [
				"APPLY_KEYWORD_MODEL",
				"APPLY_RESUME_MODEL",
				"ANTHROPIC_API_KEY",
				"LLM_PROVIDER",
				"NODE_ENV",
				"OLLAMA_BASE_URL",
				"OLLAMA_MODEL",
				"POSTGRES_PASSWORD",
				"SCORE_MODEL",
				"SCORE_BATCH_SIZE",
				"SCORE_RATE_LIMIT_MS",
				"SUPABASE_JWT_SECRET",
				"SUPABASE_PUBLISHABLE_KEY",
				"SUPABASE_SECRET_KEY",
				"SUPABASE_URL",
				"APPLY_KEYWORD_MODEL",
				"APPLY_RESUME_MODEL"
			],
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"test": {
			"dependsOn": ["^test"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
